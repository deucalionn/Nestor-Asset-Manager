# Database
DATABASE_URL=postgresql+asyncpg://nam:nam@localhost:5432/nam

# API
API_HOST=0.0.0.0
API_PORT=8000
AGENTIC_URL=http://localhost:8001

# Agent runtime (nam-agentic FastAPI)
AGENTIC_HOST=0.0.0.0
AGENTIC_PORT=8001
# Same DATABASE_URL as nam-api — LangGraph checkpoint tables live in this Postgres instance
# Runtime workspace for Deep Agent shared/user files (gitignored; mount as Docker volume in prod)
# AGENT_WORKSPACE_DIR=./data/agent_workspace

# LLM (Ollama) — runs on the host, not in Docker
LLM_MODEL=ollama:gemma4
# From containers use host.docker.internal (set automatically in docker-compose.yml)
LLM_BASE_URL=http://localhost:11434
# gemma4 is a thinking model — disable reasoning so LangChain gets visible content
LLM_REASONING=false
LLM_NUM_PREDICT=2048
LLM_NUM_CTX=32768

# Embeddings
EMBEDDING_MODEL=nomic-embed-text
# nomic-embed-text returns 768; NAM truncates to this for pgvector vector(384).
EMBEDDING_DIM=384

# Agent runtime
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
MARKET_TIMEZONE=Europe/Paris

# Yahoo Finance (nam-yahoo — shared by api and agentic)
YAHOO_RESOLVE_PREFER_SUFFIX=.PA
YAHOO_REQUEST_TIMEOUT_SEC=30
